; Minimal Godot project for standalone development and testing.
; Copy this folder to its own repo, add GodotSteam, then: python tools/run_tests.py

config_version=5

[application]

config/name="Steam Proximity Voice"
config/features=PackedStringArray("4.6", "Forward Plus")

[audio]

driver/enable_input=true

[input]

